      "envVars": [
        "RUNPOD_API_KEY",
        "RUNPOD_UPSCALE_ENDPOINT_ID"
      ],
      "estimatedCost": "$0.01-0.05 per image",
      "created": "2026-01-04",
      "updated": "2026-01-05"
