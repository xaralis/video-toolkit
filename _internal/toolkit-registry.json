          "anime",
          "oil-painting",
          "watercolor",
          "pixel-art",
          "noir",
          "pop-art",
          "sketch",
          "vintage",
          "cinematic"
        ],
        "viewpoint": [
          "front",
          "profile",
          "three-quarter",
          "looking-up",
          "looking-down"
        ]
      },
      "envVars": [
        "RUNPOD_API_KEY",
        "RUNPOD_QWEN_EDIT_ENDPOINT_ID"
