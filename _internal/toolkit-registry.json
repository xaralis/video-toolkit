      "envVars": [
        "MODAL_LTX2_ENDPOINT_URL"
      ],
      "estimatedCost": "$0.20-0.25 per scene (delegates to ltx2)",
      "created": "2026-04-04",
      "updated": "2026-04-04"
    },
