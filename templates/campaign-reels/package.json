{
  "name": "campaign-reels-template",
  "version": "1.0.0",
  "description": "1080x1920 campaign reels — clip-based composition with brand overlays",
  "scripts": {
    "studio": "npx remotion studio --port ${REMOTION_STUDIO_PORT:-3000}",
    "render": "npx remotion render src/index.ts CampaignReel out/reel.mp4",
    "render:preview": "npx remotion render src/index.ts CampaignReel out/preview.mp4 --scale=0.5",
    "build": "npx remotion bundle src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "upgrade": "npx remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.425",
    "@remotion/transitions": "4.0.425",
    "@remotion/tailwind-v4": "4.0.425",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.425",
    "tailwindcss": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "@vitest/ui": "^2.0.0"
  }
}
